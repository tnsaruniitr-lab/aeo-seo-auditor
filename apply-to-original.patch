## PATCH 8 — URL interpolation safety (general)
## Multiple files

# ANY subprocess call that passes a URL should use the list form, not
# shell=True. Examples:
#
#   BAD:  subprocess.run(f'curl -sS "{url}"', shell=True)
#   GOOD: subprocess.run(['curl', '-sS', url])
#
# ANY bash string interpolation of a URL should be avoided:
#
#   BAD:  bash "${SCRIPT_DIR}/bots_eye_view.sh" "$URL" > "$FILE"
#         (if $URL was ever user-controlled it would be a shell injection)
#   OK:   bash "${SCRIPT_DIR}/bots_eye_view.sh" "$URL" > "$FILE"
#         (in this case $URL is argv-quoted, but audit all similar paths)
#
# For cases where a single-string URL form is genuinely required, use:
#   from deterministic_checks_v2 import safe_url_for_shell
#   safe = safe_url_for_shell(url)


